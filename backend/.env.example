# Exposed port
PORT_APP=8000
PORT_MONGO=8001

# Logging
# LOG_LEVEL options: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
# LOG_FORMAT options: json, basic
LOG_FORMAT=json

# MongoDB
MONGO_USERNAME=CHANGE_ME_USER
MONGO_PASSWORD=CHANGE_ME_PASS
MONGO_URI=mongodb://CHANGE_ME_USER:CHANGE_ME_PASS@mongo:27017/?authSource=admin&replicaSet=rs0
MONGO_DB=ips-app

# JWT — use a long random string for each secret (e.g. openssl rand -hex 32)
ACCESS_TOKEN_SECRET=CHANGE_ME
ACCESS_TOKEN_EXPIRY=3600
REFRESH_TOKEN_SECRET=CHANGE_ME
REFRESH_TOKEN_EXPIRY=604800

# Seeder — initial admin credentials
ADMIN_NAME=Dhonan
ADMIN_USERNAME=admin
ADMIN_PASSWORD=12345678
USER_NAME=Default
USER_USERNAME=user
USER_PASSWORD=12345678

# User state config
# Away after must be less than offline after
USER_STATE_TO_AWAY_AFTER=300
USER_STATE_TO_OFFLINE_AFTER=1200
USER_STATE_UPDATER_CRON_PERIOD=300

# Ranging scheduler task config
RANGING_SCHEDULER_SLEEP_MS=60
RANGING_SCHEDULER_LISTEN_FOR_MS=40
RANGING_SCHEDULER_WAIT_FOR_MS=40
