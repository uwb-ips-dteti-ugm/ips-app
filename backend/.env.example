# Exposed port
PORT_APP=8000
PORT_MONGO=8081

# Logging
# LOG_LEVEL options: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
# LOG_FORMAT options: json, basic
LOG_FORMAT=json

# MongoDB
MONGO_USERNAME=CHANGE_ME_USER
MONGO_PASSWORD=CHANGE_ME_PASS
MONGO_URI=mongodb://CHANGE_ME_USER:CHANGE_ME_PASS@mongo:27017/?authSource=admin
MONGO_DB=ips-app

# JWT — use a long random string for each secret (e.g. openssl rand -hex 32)
ACCESS_TOKEN_SECRET=CHANGE_ME
ACCESS_TOKEN_EXPIRY=3600
REFRESH_TOKEN_SECRET=CHANGE_ME
REFRESH_TOKEN_EXPIRY=604800

# Seeder — initial admin credentials
ADMIN_NAME=admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
